{
  "id": "deepjelly",
  "name": "DeepJelly Desktop Avatar",
  "description": "Connect OpenClaw to DeepJelly desktop avatar for visual AI assistant experience",
  "version": "0.1.0",
  "kind": "channel",
  "channels": ["deepjelly"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "Enable DeepJelly channel"
      },
      "serverPort": {
        "type": "number",
        "description": "WebSocket server port",
        "default": 18790
      },
      "serverHost": {
        "type": "string",
        "description": "WebSocket server host",
        "default": "127.0.0.1"
      },
      "autoStart": {
        "type": "boolean",
        "description": "Auto-start server when OpenClaw starts",
        "default": true
      },
      "applicationId": {
        "type": "string",
        "description": "DeepJelly application ID (generated by DeepJelly)"
      },
      "accounts": {
        "type": "object",
        "description": "Account mappings for session routing",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "assistantId": {
              "type": "string",
              "description": "Assistant ID in DeepJelly"
            },
            "characterId": {
              "type": "string",
              "description": "Character ID for message routing"
            }
          },
          "required": ["assistantId", "characterId"]
        }
      },
      "characterId": {
        "type": "string",
        "description": "Default character ID to display (deprecated, use accounts instead)"
      },
      "appearanceId": {
        "type": "string",
        "description": "Default appearance ID (deprecated)"
      }
    },
    "required": []
  },
  "uiHints": {
    "enabled": {
      "label": "Enable DeepJelly",
      "description": "Connect to DeepJelly desktop avatar"
    },
    "serverPort": {
      "label": "Server Port",
      "description": "WebSocket server port",
      "placeholder": "18790"
    },
    "applicationId": {
      "label": "Application ID",
      "description": "DeepJelly application ID",
      "placeholder": "deepjelly_app_xxx"
    },
    "accounts": {
      "label": "Account Mappings",
      "description": "Map session keys to assistant and character IDs"
    },
    "characterId": {
      "label": "Character ID",
      "description": "Default character to display (deprecated, use accounts instead)",
      "placeholder": "miku_01"
    }
  }
}
