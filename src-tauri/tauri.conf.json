{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeepJelly",
  "version": "0.1.0",
  "identifier": "com.deepjelly.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:12260",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DeepJelly",
        "width": 500,
        "height": 500,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "minWidth": 250,
        "minHeight": 250,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; connect-src 'self' ws: wss: http://localhost:* http://127.0.0.1:* http://ipc.localhost:* ipc: data:; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline';",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "../data/**/*"
    ]
  }
}
